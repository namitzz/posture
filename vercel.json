{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": true,
  "builds": [
    { "src": "mobile_app/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "^/$", "dest": "/mobile_app/index.html" },
    { "src": "^/(.*)$", "dest": "/mobile_app/$1" }
  ]
}
